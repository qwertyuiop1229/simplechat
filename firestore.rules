rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- ユーティリティ関数 ---

    function isAuthenticated() {
      return request.auth != null;
    }

    // [Fix] exists()チェックを追加 — adminListがない場合にエラーではなくfalseを返す
    function isGlobalAdmin(appId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/artifacts/$(appId)/settings/adminList) &&
        (request.auth.token.email in get(/databases/$(database)/documents/artifacts/$(appId)/settings/adminList).data.emails);
    }

    // [Fix] exists()チェックを追加 — サーバードキュメントが存在しない場合はfalse
    function isServerAdmin(appId, serverId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/artifacts/$(appId)/servers/$(serverId)) &&
        (request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/servers/$(serverId)).data.serverAdmins
          || isGlobalAdmin(appId));
    }

    // [Fix] exists()チェックを追加
    function isJoinedServer(appId, serverId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/artifacts/$(appId)/servers/$(serverId)) &&
        (request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/servers/$(serverId)).data.joinedUsers
          || isGlobalAdmin(appId));
    }

    // --- 各コレクションのルール ---

    match /artifacts/{appId} {

      // 1. 全体設定
      match /settings/{docId} {
        allow read: if isAuthenticated();
        allow write: if isGlobalAdmin(appId);
      }

      // 2. ユーザー情報
      match /users/{userId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }

      // ============================================================
      // 旧パス互換ルール（移行完了後に削除予定）
      // ============================================================

      match /users/{userId}/profile/{docId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }

      match /status/{userId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }

      match /public/data/rooms/{roomId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
        allow update: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isGlobalAdmin(appId));
        allow delete: if isGlobalAdmin(appId);

        // [Fix] 旧実装では isAuthenticated() だけで誰でも書けた — ルーム作成者かGlobal Adminのみに絞る
        match /secrets/{docId} {
          allow read: if isGlobalAdmin(appId);
          allow create: if isAuthenticated() &&
            get(/databases/$(database)/documents/artifacts/$(appId)/public/data/rooms/$(roomId)).data.createdBy == request.auth.uid;
          allow update: if isGlobalAdmin(appId);
          allow delete: if isGlobalAdmin(appId);
        }

        match /messages/{messageId} {
          allow read: if isAuthenticated();
          allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
          // [Fix] 送信者本人でも senderId フィールドは変更不可
          allow update: if isAuthenticated() && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPinned'])
            || (resource.data.senderId == request.auth.uid
                && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['senderId']))
            || isGlobalAdmin(appId)
          );
          allow delete: if isAuthenticated() && (resource.data.senderId == request.auth.uid || isGlobalAdmin(appId));
        }

        match /readReceipts/{receiptUserId} {
          allow read: if isAuthenticated();
          allow write: if isAuthenticated() && request.auth.uid == receiptUserId;
          allow delete: if isGlobalAdmin(appId);
        }
      }

      // ============================================================
      // 新パス（サーバーベース構造）
      // ============================================================

      match /servers/{serverId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() &&
          request.resource.data.createdBy == request.auth.uid &&
          request.auth.uid in request.resource.data.serverAdmins &&
          request.auth.uid in request.resource.data.joinedUsers;
        allow update: if isServerAdmin(appId, serverId);
        allow delete: if isGlobalAdmin(appId) || isServerAdmin(appId, serverId);

        match /secrets/{docId} {
          allow read: if isServerAdmin(appId, serverId) || isGlobalAdmin(appId);
          allow create, update: if isServerAdmin(appId, serverId);
          allow delete: if isServerAdmin(appId, serverId) || isGlobalAdmin(appId);
        }

        match /rooms/{roomId} {
          allow read: if isJoinedServer(appId, serverId);
          allow create: if isJoinedServer(appId, serverId);
          allow update: if isJoinedServer(appId, serverId) &&
            (resource.data.createdBy == request.auth.uid || isServerAdmin(appId, serverId));
          allow delete: if isServerAdmin(appId, serverId) || isGlobalAdmin(appId);
        }

        match /messages/{messageId} {
          allow read: if isJoinedServer(appId, serverId);
          allow create: if isJoinedServer(appId, serverId) && request.resource.data.senderId == request.auth.uid;
          // [Fix] senderId変更を防止
          allow update: if isJoinedServer(appId, serverId) && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPinned'])
            || (resource.data.senderId == request.auth.uid
                && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['senderId']))
            || isServerAdmin(appId, serverId)
          );
          allow delete: if isJoinedServer(appId, serverId) &&
            (resource.data.senderId == request.auth.uid || isServerAdmin(appId, serverId));
        }

        match /profiles/{userId} {
          allow read: if isJoinedServer(appId, serverId);
          allow write: if isJoinedServer(appId, serverId) && request.auth.uid == userId;
        }

        match /status/{userId} {
          allow read: if isJoinedServer(appId, serverId);
          allow write: if isJoinedServer(appId, serverId) && request.auth.uid == userId;
        }

        match /readReceipts/{userId} {
          allow read: if isJoinedServer(appId, serverId);
          allow write: if isJoinedServer(appId, serverId) && request.auth.uid == userId;
          allow delete: if isServerAdmin(appId, serverId) || isGlobalAdmin(appId);
        }
      }
    }

    // ============================================================
    // [Fix/New] タイピングインジケーター用パス
    // artifacts/{appId}/... とは別の apps/{appId}/... パスのため別途定義が必要
    // ============================================================
    match /apps/{appId}/rooms/{roomId}/typing/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
