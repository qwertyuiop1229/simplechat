rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- ユーティリティ関数 ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isGlobalAdmin(appId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/artifacts/$(appId)/settings/adminList) &&
        (request.auth.token.email in get(/databases/$(database)/documents/artifacts/$(appId)/settings/adminList).data.emails);
    }

    function isListAdmin(appId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/artifacts/$(appId)/settings/listAdminList) &&
        (request.auth.token.email in get(/databases/$(database)/documents/artifacts/$(appId)/settings/listAdminList).data.emails);
    }

    function isServerAdmin(appId, serverId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/artifacts/$(appId)/servers/$(serverId)) &&
        (request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/servers/$(serverId)).data.serverAdmins
          || isGlobalAdmin(appId));
    }

    function isJoinedServer(appId, serverId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/artifacts/$(appId)/servers/$(serverId)) &&
        (request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/servers/$(serverId)).data.joinedUsers
          || isGlobalAdmin(appId));
    }

    // --- 各コレクションのルール ---

    match /artifacts/{appId} {

      // 1. 全体設定
      match /settings/{docId} {
        allow read: if isAuthenticated();
        allow write: if isGlobalAdmin(appId);
      }
      // リスト管理者は allowedEmails のみ書き込み可
      match /settings/allowedEmails {
        allow write: if isListAdmin(appId);
      }

      // 招待コードインデックス（コード→サーバーID の逆引き）
      // 認証済みユーザーなら読める、書き込みは認証済みユーザー（内容が正しくなくても実害なし）
      match /inviteIndex/{code} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
        allow delete: if isAuthenticated();
      }

      // 2. ユーザー情報
      match /users/{userId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }

      // サーバー作成クォータ（本人のみ読み書き）
      match /userQuotas/{qUserId} {
        allow read: if isAuthenticated() && request.auth.uid == qUserId;
        allow write: if isAuthenticated() && request.auth.uid == qUserId;
      }

      match /users/{userId}/profile/{docId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }

      // 3. グローバルオンライン状態
      match /status/{userId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }

      // 4. P2P音声通話シグナリング
      match /calls/{callId} {
        allow read, update: if isAuthenticated() &&
          (resource.data.caller.uid == request.auth.uid ||
           resource.data.callee.uid == request.auth.uid);
        allow create: if isAuthenticated() &&
          request.resource.data.caller.uid == request.auth.uid;
        match /callerCandidates/{candId} {
          allow read, create: if isAuthenticated();
        }
        match /calleeCandidates/{candId} {
          allow read, create: if isAuthenticated();
        }
      }

      // ============================================================
      // サーバーベース構造
      // ============================================================

      match /servers/{serverId} {
        // 単一ドキュメント取得は認証済みユーザー全員に許可（参加時のID検索・パスワード照合のため）
        allow get: if isAuthenticated();
        // 一覧取得はグローバル管理者、または自分が joinedUsers に含まれるドキュメントのみ
        allow list: if isGlobalAdmin(appId) ||
          (isAuthenticated() && request.auth.uid in resource.data.joinedUsers);

        // サーバー作成: 自分をcreatedBy・serverAdmins・joinedUsersに含める必要がある
        allow create: if isAuthenticated() &&
          request.resource.data.createdBy == request.auth.uid &&
          request.auth.uid in request.resource.data.serverAdmins &&
          request.auth.uid in request.resource.data.joinedUsers;

        // 管理者によるフル更新
        allow update: if isServerAdmin(appId, serverId);

        // 参加操作: 自分自身を joinedUsers に追加する場合のみ
        allow update: if isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['joinedUsers', 'memberCount']) &&
          request.auth.uid in request.resource.data.joinedUsers &&
          !(request.auth.uid in resource.data.joinedUsers);

        // 退出操作: 自分自身を joinedUsers/serverAdmins から削除する場合のみ
        allow update: if isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['joinedUsers', 'serverAdmins', 'memberCount']) &&
          !(request.auth.uid in request.resource.data.joinedUsers) &&
          request.auth.uid in resource.data.joinedUsers;

        // サーバー削除: グローバル管理者またはサーバー管理者
        allow delete: if isGlobalAdmin(appId) || isServerAdmin(appId, serverId);

        // サーバー内の秘密情報（管理者のみ）
        match /secrets/{docId} {
          allow read: if isServerAdmin(appId, serverId) || isGlobalAdmin(appId);
          allow create, update: if isServerAdmin(appId, serverId);
          allow delete: if isServerAdmin(appId, serverId) || isGlobalAdmin(appId);
        }

        // ルーム一覧
        match /rooms/{roomId} {
          allow read: if isJoinedServer(appId, serverId);
          allow create: if isServerAdmin(appId, serverId);
          allow update: if isServerAdmin(appId, serverId);
          allow delete: if isServerAdmin(appId, serverId) || isGlobalAdmin(appId);

          // ルーム内メッセージ
          match /messages/{messageId} {
            allow read: if isJoinedServer(appId, serverId);
            allow create: if isJoinedServer(appId, serverId) &&
              request.resource.data.senderId == request.auth.uid;
            allow update: if isJoinedServer(appId, serverId) && (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPinned'])
              || (resource.data.senderId == request.auth.uid
                  && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['senderId']))
              || isServerAdmin(appId, serverId)
            );
            allow delete: if isJoinedServer(appId, serverId) &&
              (resource.data.senderId == request.auth.uid || isServerAdmin(appId, serverId));
          }

          // 既読レシート
          match /readReceipts/{receiptUserId} {
            allow read: if isJoinedServer(appId, serverId);
            allow create, update: if isJoinedServer(appId, serverId) &&
              request.auth.uid == receiptUserId;
            allow delete: if isJoinedServer(appId, serverId) &&
              (request.auth.uid == receiptUserId || isServerAdmin(appId, serverId));
          }
        }

        // サーバー別プロフィール
        match /profiles/{profileUserId} {
          allow read: if isJoinedServer(appId, serverId);
          allow create, update: if isJoinedServer(appId, serverId) &&
            request.auth.uid == profileUserId;
          allow delete: if isJoinedServer(appId, serverId) &&
            (request.auth.uid == profileUserId || isServerAdmin(appId, serverId));
        }

        // 招待コード
        match /inviteCodes/{code} {
          // 認証済みユーザーは招待コードを読める（参加検証のため）
          allow read: if isAuthenticated();
          // 作成・無効化はサーバー管理者のみ
          allow create, delete: if isServerAdmin(appId, serverId);
          // 使用回数は +1 のインクリメントのみ許可（リセット・改ざん防止）
          allow update: if isServerAdmin(appId, serverId) ||
            (isAuthenticated() &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uses']) &&
             request.resource.data.uses == resource.data.uses + 1);
        }
      }
    }

    // タイピングインジケーター（既存パス維持）
    match /apps/{appId}/rooms/{roomId}/typing/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
