{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "simplechat",
  "version": "0.1.0",
  "identifier": "com.simplechat.desktop",
  "build": {
    "frontendDist": "../",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "simplechat",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/qwertyuiop1229/simplechat/releases/latest/download/latest.json"
      ],
      "pubkey": "dW5rbm93bg=="
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}